# =========================================================================
# THE DEN FITNESS GYM - ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env for local development and update keys accordingly.
# =========================================================================

# 1. SITE GENERAL METADATA
VITE_SITE_URL=https://thedenpeshawar.com
VITE_SITE_TITLE="The Den Fitness Gym"

# 2. WHATSAPP GATEWAY INTEGRATION
# International format without + or leading zeros (e.g., 923169636282 for Peshawar office)
VITE_WHATSAPP_NUMBER=923169636282
VITE_WHATSAPP_PREFILLED_MSG="Assalam-o-Alaikum, I want to book an elite trial workout pass at The Den Gym!"

# 3. ANALYTICS & MONITORING
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_FACEBOOK_PIXEL_ID=pixel_xxxxxxxxxx

# 4. EMAIL & BOOKING NOTIFICATION FORMS (Optional backend fallback like Formspree or EmailJS)
VITE_CONTACT_FORM_ENDPOINT=https://formspree.io/f/your_form_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_SERVICE_ID=service_xxxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxxx

# 5. BACKEND API (admin dashboard + bookings)
# Local dev: /api (Vite proxy in vite.config.js)
# Vercel production (routePrefix + API_PREFIX): set in Vercel dashboard
# VITE_API_URL=/_/backend/api
VITE_API_URL=/api

# 6. SUPABASE (set in backend/.env — never expose service role in Vite)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
